# Card Catalog — local configuration

# Path to the SQLite database file (relative to project root or absolute).
DB_PATH=data/catalog.db

# Sent to Scryfall on every request. Their docs require a clearly identifying
# string with a contact or purpose. The default below is fine for local use.
SCRYFALL_USER_AGENT=card_catalog/0.1 (personal collection tracker)

# Polite delay between Scryfall requests, in milliseconds.
# Scryfall asks for 50–100ms on most endpoints, 500ms on /cards/search and friends.
# The per-endpoint token bucket in clients/scryfall.py uses this as the floor.
SCRYFALL_DELAY_MS=100

# Bind address. Keep on 127.0.0.1 unless you really mean to expose this.
HOST=127.0.0.1
PORT=8765
